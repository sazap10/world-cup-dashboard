# Copy to ".env" and fill in to enable live data from football-data.org.
# Get a free key at https://www.football-data.org/client/register

# Server-side only — used by the dev server's caching layer (and the raw proxy)
# and never shipped to the browser bundle.
FOOTBALL_DATA_TOKEN=

# How long (ms) the server caches the matches feed before refreshing upstream.
# Upstream is called at most once per this window, no matter how many clients.
# FD_CACHE_TTL_MS=60000

# Upstream API origin (override only for testing against a mock).
# FD_UPSTREAM=https://api.football-data.org

# How long (ms) to wait on the upstream call before giving up. A timeout keeps
# a hung upstream from stalling clients — the last cached data keeps serving.
# FD_UPSTREAM_TIMEOUT_MS=8000

# --- Broadcaster ("where to watch") scrape ---------------------------------
# The UK broadcaster allocation is scraped from live-footballontv.com at runtime
# and merged over the static tables (no token needed; works in seed-only mode).
# The server caches the page; the browser parses it client-side.

# Source page (override to point at a saved fixture for offline dev/CI).
# BCAST_UPSTREAM=https://www.live-footballontv.com/live-world-cup-football-on-tv.html

# How long (ms) the server caches the scrape before refetching (default 6h).
# BCAST_CACHE_TTL_MS=21600000

# How long (ms) to wait on the scrape before giving up.
# BCAST_UPSTREAM_TIMEOUT_MS=8000

# Client-visible (safe to leave unset):
# VITE_USE_LIVE=true                  # set "false" to force the seed dataset
# VITE_MATCHES_URL=/api/wc/matches    # cached endpoint; set to a prod proxy URL,
#                                     # or "/fd/v4/competitions/WC/matches" for raw
# VITE_BROADCASTERS_URL=/api/wc/broadcasters  # cached where-to-watch endpoint
# VITE_COMPETITION=WC                 # football-data.org competition code (server-side)
