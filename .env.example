# Copy to ".env" and fill in to enable live data from football-data.org.
# Get a free key at https://www.football-data.org/client/register

# Server-side only — injected into API requests by the Vite dev proxy and
# never shipped to the browser bundle.
FOOTBALL_DATA_TOKEN=

# Optional overrides (client-visible; safe to leave unset):
# VITE_USE_LIVE=true            # set to "false" to force the seed dataset
# VITE_API_BASE=/fd             # same-origin base the proxy forwards
# VITE_COMPETITION=WC           # football-data.org competition code
