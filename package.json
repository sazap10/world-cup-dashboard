{
  "name": "world-cup-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A timezone-aware FIFA World Cup 2026 dashboard with fixtures, results, group tables, knockout bracket, and UK broadcast info.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "go run ./server",
    "serve": "npm run build && go run ./server",
    "build:server": "CGO_ENABLED=0 go build -trimpath -ldflags=\"-s -w\" -o bin/server ./server",
    "typecheck": "tsc -b --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "engines": {
    "node": ">=26"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
